<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.puzzleguardinterface.controllers.PersonalInfoResetController"
            prefHeight="400.0" prefWidth="600.0"
            fx:id="root">

    <center>
        <BorderPane styleClass="borderPane">
            <top>
                <HBox alignment="CENTER" BorderPane.alignment="CENTER">
                    <padding>
                        <Insets top="25" right="20" bottom="25" left="20" />
                    </padding>
                    <Button styleClass="arrowBtn" >
                        <graphic>
                            <ImageView fitHeight="25" fitWidth="35">
                                <Image url="@../../../assets/img/leftArrow.png"/>
                            </ImageView>
                        </graphic>
                        <padding>
                            <Insets top="20" right="20" bottom="20" left="20" />
                        </padding>
                    </Button>
                    <Region HBox.hgrow="ALWAYS" />
                    <Text   strokeType="OUTSIDE" strokeWidth="0.0" text="Enter your new Email" styleClass="head-text" textAlignment="CENTER" stroke="greenyellow">-->
                        <VBox.margin>
                            <Insets top="20" right="0" bottom="0" left="0" />
                        </VBox.margin>
                    </Text>
                    <Pane HBox.hgrow="ALWAYS" />
                </HBox>
            </top>
            <center>
                <VBox  spacing="40" alignment="CENTER"  prefWidth="800" maxWidth="800" minWidth="800">

                </VBox>
            </center>
